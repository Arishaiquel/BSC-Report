FROM node:20-alpine AS build
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build:api

FROM node:20-alpine AS runtime
WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev

COPY --from=build /app/dist-api ./dist-api

ENV NODE_ENV=production
ENV API_ONLY=true
ENV PORT=5000

EXPOSE 5000

CMD ["npm", "run", "start:api"]
